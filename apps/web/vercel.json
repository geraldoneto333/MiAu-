{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && npm install && npm run build -w apps/api && npm run build -w apps/web",
  "installCommand": "cd ../.. && npm install",
  "framework": "nextjs",
  "rewrites": [
    { "source": "/auth/:path*", "destination": "/api/nest" },
    { "source": "/api/tutores/:path*", "destination": "/api/nest" },
    { "source": "/api/tutores", "destination": "/api/nest" },
    { "source": "/api/pets/:path*", "destination": "/api/nest" },
    { "source": "/api/pets", "destination": "/api/nest" },
    { "source": "/api/servicos/:path*", "destination": "/api/nest" },
    { "source": "/api/servicos", "destination": "/api/nest" },
    { "source": "/api/agendamentos/:path*", "destination": "/api/nest" },
    { "source": "/api/agendamentos", "destination": "/api/nest" },
    { "source": "/api/avisos/:path*", "destination": "/api/nest" },
    { "source": "/api/avisos", "destination": "/api/nest" },
    { "source": "/openapi.json", "destination": "/api/nest" },
    { "source": "/api-docs/:path*", "destination": "/api/nest" }
  ],
  "functions": {
    "api/nest.ts": {
      "includeFiles": "../api/dist/**"
    }
  }
}
